##################################################################

my (@in_1, @in_2, @ex_1, @ex_2);

if(length(sqrt(2.0)) < 31) {
    if(196869 > Math::MPFR::MPFR_VERSION()) {
      plan skip_all => 'MPFR library version needs to be at least 3.1.5';
      done_testing();
      exit 0;
    }
  warn "\n NV is 80-bit extended precision long double\n";
  @in_1 = @in_1_64;
  @in_2 = @in_2_64;
  @ex_1 = @ex_1_64;
  @ex_2 = @ex_2_64;
}
else {
  if($Config{nvtype} eq 'long double') {
    if(262659 > Math::MPFR::MPFR_VERSION()) {
      plan skip_all => 'MPFR library version needs to be at least 4.2.3';
      done_testing();
      exit 0;
    }
    warn "\n NV is IEEE 754 long double\n";
  }
  else { warn "\n NV is __float128\n" }
  @in_1 = @in_1_113;
  @in_2 = @in_2_113;
  @ex_1 = @ex_1_113;
  @ex_2 = @ex_2_113;
}

my $len1 = scalar(@in_1);
my $len2 = scalar(@in_2);

cmp_ok($len1, '==', scalar(@ex_1), "1st set of arrays match in size");
cmp_ok($len2, '==', scalar(@ex_2), "2nd set of arrays match in size");

$len1--;
$len2--;

Rmpfr_set_default_prec(128);

for my $i (0 .. $len1) {
  cmp_ok(Rmpfr_get_NV(Math::MPFR->new($in_1[$i], 2), MPFR_RNDN), '==', $ex_1[$i], "Index $i: 1st sets agree");
}

Rmpfr_set_default_prec(64);

for my $i (0 .. $len2) {
  cmp_ok(Rmpfr_get_NV(Math::MPFR->new($in_2[$i], 2), MPFR_RNDN), '==', $ex_2[$i], "Index $i: 2nd sets agree");
}

done_testing();

